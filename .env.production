# ===== Brillance Production Environment =====
# Copy this to Vercel (frontend) and Railway (backend)

# --- Required (set real values in Cloudflare Dashboard) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=
OPENAI_API_KEY=

# --- Stripe (get from https://dashboard.stripe.com) ---
# Set these in Cloudflare Dashboard > Environment Variables (never commit real secrets)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_TEAM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# --- Backend API (frontend Vite) ---
VITE_API_URL=https://backend-design-production.up.railway.app

# --- Optional (defaults to https://your-app.vercel.app) ---
FRONTEND_URL=https://backend-design-production.up.railway.app

# --- Vite (frontend only) ---
# Set these in Cloudflare Dashboard (never commit real values)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
